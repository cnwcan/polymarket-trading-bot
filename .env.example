# =============================================================================
# Poly Scalper — environment variable template
# -----------------------------------------------------------------------------
# Usage: Copy this file to `.env` and fill in your values.
#        Never commit `.env` to Git (it contains secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# Run mode
# -----------------------------------------------------------------------------
# PRODUCTION=false → simulation (no live orders). PRODUCTION=true → live trading.
PRODUCTION=false

# -----------------------------------------------------------------------------
# Polymarket API endpoints (usually leave defaults; same defaults exist in code)
# -----------------------------------------------------------------------------
# GAMMA_API_URL=https://gamma-api.polymarket.com
# CLOB_API_URL=https://clob.polymarket.com

# Optional: use pre-derived CLOB API credentials if you manage keys yourself.
# If unset, the bot runs createOrDeriveApiKey using PRIVATE_KEY.
# API_KEY=
# API_SECRET=
# API_PASSPHRASE=

# -----------------------------------------------------------------------------
# Wallet & signatures (required for PRODUCTION / live orders)
# -----------------------------------------------------------------------------
# Never share it; keep it only in `.env` on this machine.
PRIVATE_KEY=

# Polymarket proxy / profile wallet address shown in the UI (0x…).
# May differ from your MetaMask address — use the Polymarket “wallet” address.
PROXY_WALLET_ADDRESS=

# Signature type (must match Polymarket CLOB expectations):
#   0 = direct EOA
#   1 = Proxy
#   2 = Gnosis Safe (common with Magic / proxy setups)
SIGNATURE_TYPE=2

# Optional: HTTP(S) outbound proxy (corporate network, geo restrictions, etc.).
# Example: http://user:pass@host:port
# POLYMARKET_PROXY_URL=

# -----------------------------------------------------------------------------
# Markets & timing
# -----------------------------------------------------------------------------
# Comma-separated: btc, eth, sol, xrp — the bot currently uses the first market in the list.
MARKETS=btc

# Candle period: 5m, 15m, or 1h (code derives duration from this).
TIMEFRAME=5m

# Main loop interval and market closure check (milliseconds / seconds).
CHECK_INTERVAL_MS=500
MARKET_CLOSURE_CHECK_INTERVAL_SECONDS=10

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
# Port for the web UI and REST API (http://localhost:DASHBOARD_PORT).
DASHBOARD_PORT=3000

# Starting balance for simulation UI display (USDC).
STARTING_BALANCE=20

# -----------------------------------------------------------------------------
# Telegram trade alerts (optional)
# -----------------------------------------------------------------------------
# On each closed position, the bot can POST an HTML summary to Telegram via Bot API.
# If either variable is missing or empty, alerts are skipped (no error).
#
# Bot token: open Telegram, talk to @BotFather → /newbot → copy the HTTP API token.
TELEGRAM_BOT_TOKEN=
#
# Chat ID where messages are delivered (your user ID for DMs, or a group/channel ID).
# Tip: message @userinfobot or use @RawDataBot to see IDs (groups often look like -1001234567890).
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Scalper — position & risk
# -----------------------------------------------------------------------------
# Per-trade position size range (USDC).
MIN_POSITION_USDC=1
MAX_POSITION_USDC=2

# Maximum number of concurrent open positions.
MAX_OPEN_POSITIONS=3

# Daily loss cap (USDC); risk logic triggers beyond this.
DAILY_LOSS_LIMIT=8

# Profit / loss ratios (0.12 ≈ 12% take-profit style, 0.20 ≈ 20% stop style usage).
TAKE_PROFIT_PERCENT=0.12
STOP_LOSS_PERCENT=0.20

# Entry momentum threshold (e.g. 0.10 = 0.10%) and measurement window (ms).
ENTRY_THRESHOLD_PERCENT=0.10
MOMENTUM_WINDOW_MS=30000

# Entry price filters: ask must fall in this band (token price 0–1).
MIN_ENTRY_ASK=0.10
MAX_ENTRY_ASK=0.92

# Minimum gap between trades (seconds); exit how many seconds before period end.
SCALP_COOLDOWN_SECONDS=30
EXIT_BEFORE_CLOSE_SECONDS=15

# -----------------------------------------------------------------------------
# Late entry mode (optional; default off)
# -----------------------------------------------------------------------------
LATE_ENTRY_ENABLED=false
# How many seconds before period end to allow “late entry” (e.g. last 90s).
LATE_ENTRY_WINDOW_SECONDS=90
LATE_ENTRY_MIN_ASK=0.90
LATE_ENTRY_MAX_POSITION_USDC=15

# If winning and ask is above this near expiry, prefer holding to resolution.
HOLD_TO_RESOLUTION_ASK_THRESHOLD=0.92

# -----------------------------------------------------------------------------
# Whale Guard — sudden spread / BTC spike protection
# -----------------------------------------------------------------------------
WHALE_GUARD_SPREAD_LIMIT=4.0
WHALE_GUARD_SPIKE_THRESHOLD=0.0015

# -----------------------------------------------------------------------------
# Binance WebSocket (price feed)
# -----------------------------------------------------------------------------
# Default BTC/USDT agg trade; change URL per Binance docs for other symbols.
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@aggTrade

# -----------------------------------------------------------------------------
# Developer / logging
# -----------------------------------------------------------------------------
# Minimum interval between entry debug logs (ms); 0 or large value = fewer logs.
ENTRY_DEBUG_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Dump-and-hedge / notification (values included in startup webhook payload)
# -----------------------------------------------------------------------------
# Sent to the internal notification layer on bot startup; keep aligned with your strategy.
DUMP_HEDGE_SHARES=10
DUMP_HEDGE_SUM_TARGET=0.95
DUMP_HEDGE_MOVE_THRESHOLD=0.15
DUMP_HEDGE_WINDOW_MINUTES=2
DUMP_HEDGE_STOP_LOSS_MAX_WAIT_MINUTES=5
DUMP_HEDGE_STOP_LOSS_PERCENTAGE=0.2